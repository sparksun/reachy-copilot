# Local dev — NEVER COMMIT THIS FILE

# ── 推荐：OAuth 模式（支持共享机器人） ────────────────────────
# 在 https://huggingface.co/settings/applications/new 创建 OAuth 应用
# Homepage URL + Redirect URI: http://localhost:5173  Scopes: openid profile
# 设置后 HF_TOKEN / HF_USERNAME 会被忽略（OAuth 优先）
HF_OAUTH_CLIENT_ID=

# ── 备用：PAT 模式（仅适用于你亲自拥有机器人的情况） ──────────
# 若机器人是别人共享给你的，PAT 无法看到机器人（信令服务器过滤）
HF_TOKEN=hf_xxx
HF_USERNAME=your-hf-username

# Hermes Agent API（从项目 .env 复制）
HERMES_URL=your-hermes-api-url
HERMES_KEY=your-api-key-here
